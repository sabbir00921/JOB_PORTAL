{
  "compilerOptions": {
    /* ── Output ── */
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "rootDir": "./src",
    "outDir": "./dist",

    /* ── Features ── */
    "sourceMap": true,
    "declaration": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    /* ── Type Checking ── */
    "strict": true,
    "skipLibCheck": true,

    /* ── Types ── */
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
