# ==============================================================================
# HESTEKA BACKEND - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to .env and fill in the actual values.
# DO NOT commit the .env file to version control.

# ----------------- Server -----------------
NODE_ENV=development
PORT=5000
ADMIN_EMAILS=admin@example.com,superadmin@example.com

# ----------------- Database (MongoDB) -----------------
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/hesteka?retryWrites=true&w=majority

# ----------------- Redis -----------------
# Required for caching, real-time features, and rate limiting
REDIS_URL=redis://localhost:6379

# ----------------- Security (JWT & Bcrypt) -----------------
BCRYPT_SALT_ROUNDS=10

# Main JWT Secret (Used for general token logic)
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRE=1h

# Specific Access/Refresh Token Secrets
ACCESS_TOKEN_SECRET=your_access_token_secret
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRES=7d

# Password Reset
PASSWORD_RESET_TOKEN_SECRET=your_password_reset_secret
PASSWORD_RESET_TOKEN_EXPIRE=10m

# ----------------- Authentication Providers -----------------
# Google Cloud Console Credentials
GOOGLE_CLIENT_ID=your_google_web_client_id
GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id
GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id

# Apple Developer Credentials
APPLE_CLIENT_ID=your_apple_client_id

# ----------------- Media Storage (Cloudinary) -----------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ----------------- Email (Nodemailer / SMTP) -----------------
HOST_MAIL=your_email@gmail.com
APP_PASSWORD=your_app_specific_password
APP_NAME=HESTEKA

# ----------------- Payment Gateways -----------------
# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox # or live
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# ----------------- Real-time & Push Notifications (Firebase) -----------------
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="your_firebase_private_key"
FIREBASE_DATABASE_URL=your_firebase_database_url


# ----------------- E-commerce (Shopify) -----------------
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...

# ----------------- Frontend & Rate Limiting -----------------
FRONTEND_URL=http://localhost:3000
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX=100
RATE_LIMIT_DELAY=50
